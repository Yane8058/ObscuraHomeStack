# ======= Base Path ======= #
BASE_PATH=<path/to/your/containers>

# ======= User & Timezone ======= #
PUID=<your_puid>
PGID=<your_pgid>
USER_ID=<your_uid:your_gid>
TZ=<your_timezone>

# ======= MariaDB ======= #
MYSQL_ROOT_PASSWORD=<your_root_password>
MYSQL_DATABASE=<your_database_name>
MYSQL_USER=<your_database_user>
MYSQL_PASSWORD=<your_database_password>

# ======= Grafana ======= #
GF_SECURITY_ADMIN_USER=<your_grafana_user>
GF_SECURITY_ADMIN_PASSWORD=<your_grafana_password>

# ======= Ports ======= #
PORT_NEXTCLOUD_HTTPS=<port>
PORT_NEXTCLOUD_HTTP=<port>
PORT_QBITTORRENT=<port>
PORT_QBITTORRENT_TORRENT=<port>
PORT_ADGUARD_DNS=<port>
PORT_ADGUARD_UI=<port>
PORT_ADGUARD_SETUP=<port>
PORT_ADGUARD_DOT=<port>
PORT_NODE_EXPORTER=<port>
PORT_CADVISOR=<port>
PORT_PROMETHEUS=<port>
PORT_ALERTMANAGER=<port>
PORT_GRAFANA=<port>
PORT_KAVITA=<port>
PORT_NAVIDROME=<port>
PORT_ACTUAL_BUDGET=<port>
PORT_FIREFLY=<port>
DB_FIREFLY_PORT=<port>
LOCAL_IP=<local_ip>
APP_KEY=<32_chars_key>

# ===================================================================================================
# MODULE: Gaming
# Enable with:
#   docker compose -f docker-compose.yml \
#                  -f modules/jellyfin/docker-compose-gaming.yml up -d
# ===================================================================================================
MINECRAFT_SERVER=<your_server_name>
PORT_MINECRAFT=<port>

# ===================================================================================================
# MODULE: Domotic-House
# Enable with:
#   docker compose -f docker-compose.yml \
#                  -f modules/jellyfin/docker-compose-domohouse.yml up -d
# ===================================================================================================
PORT_HOMEASSISTANT=<port>
PORT_MOSQUITTO=<port>
PORT_ZIGBEE2MQTT=<port>

# ===========================================================
# MODULE: Paperless Suite
# Enable with:
#   docker compose -f docker-compose.yml \
#                  -f modules/paperless/docker-compose.yml up -d
# ===========================================================

# ======= Paperless — Ports ======= #
PORT_PAPERLESS=<port>
PORT_OLLAMA=<port>
PORT_PAPERLESS_AI=<port>
PORT_PAPERLESS_GPT=<port>

# ======= Paperless — App ======= #
PAPERLESS_SECRET_KEY=<random_string_min_50_chars>
PAPERLESS_URL=<http://local_ip:port>
PAPERLESS_OCR_LANGUAGE=<lang>

# ======= Paperless — MariaDB (dedicated credentials) ======= #
# Do NOT reuse MYSQL_USER/MYSQL_PASSWORD — those belong to Nextcloud
# Create the DB manually before first boot (see modules/paperless/README.md)
PAPERLESS_DB_NAME=<your_paperless_db_name>
PAPERLESS_DB_USER=<your_paperless_db_user>
PAPERLESS_DB_PASSWORD=<your_paperless_db_password>

# ======= Paperless — Admin account ======= #
# First boot only — comment out after setup and restart paperless
PAPERLESS_ADMIN_USER=<your_admin_user>
PAPERLESS_ADMIN_PASSWORD=<your_admin_password>
PAPERLESS_ADMIN_EMAIL=<your_admin_email>

# ======= Paperless — Ollama / AI ======= #
OLLAMA_MODEL=<model_name>
# OLLAMA_VISION_MODEL=<model_name>        # uncomment to enable Vision OCR

# ======= Paperless — API Token ======= #
# Leave empty on first boot.
# Retrieve from: UI -> Admin -> Profile -> API Token
# Then restart: docker compose ... restart paperless_ai paperless_gpt
PAPERLESS_API_TOKEN=

# ======= Paperless — AI Scan ======= #
PAPERLESS_AI_SCAN_INTERVAL=<minutes>

# =========================================================================
# MODULE: Jellyfin
# Enable with:
#   docker compose -f docker-compose.yml \
#                  -f modules/jellyfin/docker-compose-jellyfin.yml up -d
# =========================================================================

# ======= Jellyfin — App ======= #
JELLYFIN_URL=<http://local_ip>


# ======= Ports ======= #
PORT_JELLYFIN=<port>